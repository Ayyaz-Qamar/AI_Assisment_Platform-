# PostgreSQL Database
DATABASE_URL=postgresql://postgres:admin123@localhost:5432/assessment_db

# JWT Settings
SECRET_KEY=change-this-secret-key-in-production-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ML Paths
ML_MODEL_PATH=app/ml/model.joblib
DATASET_PATH=app/ml/dataset.csv

# Default Admin (auto-seeded on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123